{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"types": ["vite/client"],
		"noFallthroughCasesInSwitch": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"erasableSyntaxOnly": true
	},
	"include": [
		"app/**/*.ts",
		"app/**/*.d.ts",
		"app/**/*.vue",
		"i18n/**/*.ts",
		"scripts/**/*.ts",
		"tests/**/*.ts",
		"vitest.config.ts",
		"nuxt.config.ts",
		"drizzle.config.ts",
		"eslint.config.ts"
	],
	"exclude": ["node_modules", ".nuxt", ".output", "dist"]
}
